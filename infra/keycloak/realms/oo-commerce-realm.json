      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "customer-user",
      "enabled": true,
      "email": "customer-user@localhost",
      "emailVerified": true,
      "firstName": "Customer",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "Customer123!",
          "temporary": false
        }
      ],
      "realmRoles": ["customer"]
    }
  ]
