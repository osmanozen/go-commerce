    {
      "name": "1. Catalog Service (8081)",
      "description": "Product and category management queries and commands.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sony PlayStation 5 Pro\",\n  \"description\": \"Next gen console with ultra high-speed SSD.\",\n  \"sku\": \"SONY-PS5-PRO-01\",\n  \"priceAmount\": 29999.00,\n  \"priceCurrency\": \"TRY\",\n  \"categoryId\": \"e-1234-abcd-5678\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/catalog/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "catalog", "products"]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/api/catalog/products/{{product_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "catalog", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
