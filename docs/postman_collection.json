        },
        {
          "name": "Get Stock Level",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8084/api/inventory/stock/{{product_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["api", "inventory", "stock", "{{product_id}}"]
            }
          }
        },
        {
          "name": "Batch Get Stock Levels",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productIds\": [\n    \"{{product_id}}\"\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8084/api/inventory/stock/levels",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["api", "inventory", "stock", "levels"]
            }
          }
        }
