          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Guest-ID", "value": "guest-87asjdha8s7", "description": "Mock ID for unauthenticated users." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"productName\": \"Sony PlayStation 5 Pro\",\n  \"unitPrice\": 29999.00,\n  \"currency\": \"TRY\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8082/api/cart/items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["api", "cart", "items"]
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Guest-ID", "value": "guest-87asjdha8s7" }
