        {
          "name": "Adjust Stock (Add Stock)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adjustmentType\": 1,\n  \"quantity\": 100,\n  \"reason\": \"Initial warehouse stocking\"\n}"
            },
            "url": {
              "raw": "http://localhost:8084/api/inventory/stock/{{product_id}}/adjust",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["api", "inventory", "stock", "{{product_id}}", "adjust"]
